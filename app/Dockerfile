FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
WORKDIR /repo
RUN corepack enable

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml* .npmrc ./
COPY app/package.json ./app/package.json
# api/package.json is copied so the workspace matches the lockfile for a frozen
# install, but we only install the web app's own dependency tree — the API's
# heavy deps (AWS SDK, Prisma, etc.) aren't needed to build the Next.js app and
# bloated the image enough to hit ENOSPC on smaller disks.
COPY api/package.json ./api/package.json
RUN pnpm install --frozen-lockfile --filter caseiq-web...

FROM base AS builder
COPY --from=deps /repo/node_modules ./node_modules
COPY --from=deps /repo/app/node_modules ./app/node_modules
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml* turbo.json* ./
COPY app ./app
# app/src/lib/api.ts imports from the repo-root shared/ workspace (../../../shared/*),
# so it must be present in the build image or the Next.js type-check fails.
COPY shared ./shared
WORKDIR /repo/app
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
RUN pnpm build

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Next.js standalone output. With outputFileTracingRoot at the repo root, the
# standalone bundle mirrors the workspace layout: it contains a top-level
# node_modules/ and the app under ./app, so server.js lives at ./app/server.js.
COPY --from=builder /repo/app/.next/standalone ./
COPY --from=builder /repo/app/.next/static ./app/.next/static
COPY --from=builder /repo/app/public ./app/public

USER nextjs
EXPOSE 3000

# server.js is generated by Next's standalone output and needs no pnpm/corepack.
CMD ["node", "app/server.js"]
