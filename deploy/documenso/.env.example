# Copy to `.env` in this directory (docker compose auto-loads it) and fill in.
# These values configure the self-hosted Documenso instance only. The keys that
# tell the ClearCaseIQ API how to reach Documenso live in api/.env (see bottom).

# ---- Public HTTPS URL this Documenso instance is served at ----
# Put a reverse proxy (nginx/ALB/Caddy) in front of the container's port 3000.
DOCUMENSO_WEBAPP_URL=https://sign.yourfirm.com

# ---- Postgres ----
POSTGRES_USER=documenso
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=documenso

# ---- App secrets — generate each with: openssl rand -base64 32 ----
NEXTAUTH_SECRET=
NEXT_PRIVATE_ENCRYPTION_KEY=
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=

# ---- Outbound email (signing invitations). AWS SES SMTP example ----
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=ClearCaseIQ
SMTP_FROM_ADDRESS=no-reply@yourfirm.com

# ---- PDF signing certificate passphrase ----
# Used when generating cert.p12 (see docker-compose.yml header) and to open it.
SIGNING_PASSPHRASE=change-me-cert-password

# =====================================================================
# The following DO NOT go in this file. After Documenso is running and
# you've created an API token + webhook, set these in ../../api/.env:
#
#   DOCUMENSO_API_URL=https://sign.yourfirm.com/api/v2
#   DOCUMENSO_API_KEY=<Settings -> API Tokens>
#   DOCUMENSO_WEBHOOK_SECRET=<the secret you set on the webhook>
#   ESIGN_PROVIDER=documenso
# =====================================================================
