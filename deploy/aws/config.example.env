# AWS Deployment Configuration
# Copy to config.env and fill in your values

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# ECR Repository names
ECR_API_REPO=legal-api

# RDS MySQL (create in RDS console first)
DATABASE_URL=mysql://admin:your-password@your-db.xxxxx.us-east-1.rds.amazonaws.com:3306/injury_intelligence

# App Runner will use these env vars - set in AWS Console or via CLI
# JWT_SECRET=your-jwt-secret
# OPENAI_API_KEY=sk-...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# APPLE_CLIENT_ID=...
# APPLE_TEAM_ID=...
# APPLE_KEY_ID=...
# APPLE_PRIVATE_KEY=...

# S3 Buckets (create in S3 console)
S3_WEB_BUCKET=legal-web-your-unique-id
S3_UPLOADS_BUCKET=legal-uploads-your-unique-id
