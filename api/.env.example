# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/injury_intelligence?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-here"

# OpenAI (optional, for ChatGPT analysis)
OPENAI_API_KEY=

# ML service integration
ML_SERVICE_URL=http://localhost:8000
# fallback = heuristics only, shadow = heuristics plus ML comparison, primary = ML-first with heuristic fallback
ML_PREDICTION_MODE=shadow
ML_REQUEST_TIMEOUT_MS=5000
ML_RETRIEVAL_ENABLED=true
ML_RETRIEVAL_TOP_K=4
ML_PROMPT_VERSION=legal-grounded-v1

# Twilio SMS (optional, for case routing Accept/Decline via text)
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend Email (optional, for real outbound email delivery)
# Get credentials at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# URLs
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# LegalMatch production import
# Set NODE_ENV=production and LEGALMATCH_ALLOW_PRODUCTION_IMPORT=true to enable.
LEGALMATCH_ALLOW_PRODUCTION_IMPORT=false
LEGALMATCH_DRY_RUN=false
LEGALMATCH_MAX_PROFILES=100
LEGALMATCH_FETCH_DELAY_MS=1500
LEGALMATCH_FETCH_MODE=auto
# Browser mode requires Playwright Chromium to be installed.
LEGALMATCH_BROWSER_HEADLESS=true
# Discovery mode: auto, sitemap, search, browser-search, or browser-index.
LEGALMATCH_DISCOVERY_MODE=auto
# Optional: skip already imported LegalMatch source URLs so repeated runs can advance to new profiles.
LEGALMATCH_SKIP_IMPORTED=false
# Optional: skip the first N discovered URLs before importing the next batch.
LEGALMATCH_DISCOVERY_OFFSET=0
# Optional: for browser-search discovery, paginate up to this many results pages per query.
LEGALMATCH_SEARCH_PAGES_PER_QUERY=3
# Optional: for browser-index discovery, paginate this many attorney index pages.
LEGALMATCH_INDEX_PAGES=4
# Optional: comma-separated list of public attorney profile URLs to import directly.
LEGALMATCH_PROFILE_URLS=
# Optional: newline or comma-separated search queries for indexed-profile fallback discovery.
LEGALMATCH_SEARCH_QUERIES=
# Optional: override sitemap discovery entrypoint.
LEGALMATCH_SITEMAP_URL=https://www.legalmatch.com/sitemap.xml.gz

# HTTP server bind (default 0.0.0.0 = all interfaces, so phones on LAN can connect using your PC IP)
# HOST=0.0.0.0
