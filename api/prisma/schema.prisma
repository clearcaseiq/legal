model LeadSubmission {
  id           String     @id @default(cuid())
  assessmentId String     @unique
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  // Lead Quality Metrics
  viabilityScore Float @default(0)
  liabilityScore Float @default(0)
  causationScore Float @default(0)
  damagesScore   Float @default(0)

  // Evidence Checklist
  evidenceChecklist String? @db.Text // JSON checklist of uploaded/missing documents

  // Exclusivity & Source
  isExclusive   Boolean @default(false)
  sourceType    String // 'organic_search', 'paid_ad', 'referral', 'direct'
  sourceDetails String? // JSON additional source info

  // Lead Hotness
  submittedAt   DateTime  @default(now())
  lastContactAt DateTime?
  hotnessLevel  String    @default("warm") // 'hot', 'warm', 'cold'

  // Attorney Assignment
  assignedAttorneyId String?
  assignedAttorney   Attorney? @relation(fields: [assignedAttorneyId], references: [id], onDelete: SetNull)
  assignmentType     String    @default("shared") // 'exclusive', 'first_look', 'shared'

  // Conversion Tracking
  status      String    @default("submitted") // 'submitted', 'contacted', 'consulted', 'retained', 'rejected'
  convertedAt DateTime?

  // Routing Lifecycle (Step 17)
  lifecycleState String @default("routing_active") // assessment_completed, routing_active, attorney_review, attorney_matched, consultation_scheduled, engaged, closed
  routingLocked  Boolean @default(false) // true when attorney accepts - stops further routing

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactAttempts   LeadContact[]
  caseContacts     CaseContact[]
  conflictChecks    ConflictCheck[]
  qualityReports    QualityReport[]
  providerReferrals ProviderReferral[]
  decisionMemory    DecisionMemory?
  documentRequests  DocumentRequest[]

  @@map("lead_submissions")
}

