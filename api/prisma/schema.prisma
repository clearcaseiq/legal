// Evidence Upload & Management Models

model EvidenceFile {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  // File Information
  originalName String
  filename     String
  mimetype     String
  size         Int
  filePath     String
  fileUrl      String

  // Evidence Classification
  category    String // 'medical_records', 'police_report', 'bills', 'photos', 'correspondence', 'other'
  subcategory String? // 'medical_bill', 'insurance_doc', 'accident_photo', 'damage_photo', etc.
  description String?
  dataType    String  @default("unstructured") // 'structured', 'unstructured'
  tags        String? // JSON array of tags
  relevanceScore Float @default(0)

  // Upload Metadata
  uploadMethod String    @default("drag_drop") // 'drag_drop', 'camera', 'file_picker'
  captureDate  DateTime? // For camera uploads
  location     String? // GPS coordinates for photos

  // EXIF Data (JSON)
  exifData String? // Camera settings, GPS, timestamp

  // Processing Status
  processingStatus String  @default("pending") // 'pending', 'processing', 'completed', 'failed'
  ocrText          String? // Extracted text from OCR
  aiSummary        String?
  aiClassification String?
  aiHighlights     String? // JSON array of highlight snippets

  // HIPAA Compliance
  isHIPAA         Boolean @default(false)
  accessLevel     String  @default("private") // 'private', 'attorney', 'shared'
  retentionPolicy String? // Retention period
  provenanceSource String?
  provenanceNotes  String?
  provenanceActor  String?
  provenanceDate   DateTime?

  // Verification
  isVerified Boolean   @default(false)
  verifiedBy String? // Attorney ID who verified
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  extractedData  ExtractedData[]
  processingJobs EvidenceProcessingJob[]
  accessLogs     EvidenceAccessLog[]
  annotations    EvidenceAnnotation[]

  @@map("evidence_files")
}

model EvidenceAnnotation {
  id             String       @id @default(cuid())
  evidenceFileId String
  evidenceFile   EvidenceFile @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content        String
  anchor         String? // optional location reference
  pageNumber     Int?
  createdAt      DateTime     @default(now())

  @@map("evidence_annotations")
}

model ExtractedData {
  id             String       @id @default(cuid())
  evidenceFileId String
  evidenceFile   EvidenceFile @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  // Medical Codes
  icdCodes String? // JSON array of ICD codes
  cptCodes String? // JSON array of CPT codes

  // Financial Data
  dollarAmounts String? // JSON array of monetary values found
  totalAmount   Float?
  currency      String  @default("USD")

  // Timeline Data
  dates    String? // JSON array of dates found
  timeline String? // JSON structured timeline

  // Key Entities
  entities String? // JSON of extracted entities (names, locations, etc.)
  keywords String? // JSON array of relevant keywords

  // Confidence Scores
  confidence     Float   @default(0.0)
  isManualReview Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("extracted_data")
}

model EvidenceProcessingJob {
  id             String       @id @default(cuid())
  evidenceFileId String
  evidenceFile   EvidenceFile @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  // Job Details
  jobType  String // 'ocr', 'nlp', 'classification', 'full_processing'
  status   String @default("queued") // 'queued', 'running', 'completed', 'failed'
  priority Int    @default(5) // 1-10, higher = more priority

  // Processing Details
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?

  // Results
  results String? // JSON results from processing

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("evidence_processing_jobs")
}

model EvidenceAccessLog {
  id             String       @id @default(cuid())
  evidenceFileId String
  evidenceFile   EvidenceFile @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  // Access Details
  accessedBy String // User ID or Attorney ID
  accessType String // 'view', 'download', 'share'
  ipAddress  String?
  userAgent  String?

  // Purpose
  purpose  String? // Reason for access
  duration Int? // Seconds spent accessing

  createdAt DateTime @default(now())

  @@map("evidence_access_logs")
}

model Court {
  courtId    BigInt   @id @default(autoincrement())
  state      String   @db.VarChar(100)
  county     String   @db.VarChar(255)
  courtName  String   @db.VarChar(500)
  courthouse String?  @db.Text
  judges     Judge[]
  caseRecords CaseRecord[]

  @@unique([state, county, courtName])
  @@map("courts")
}

model CaseRecord {
  casePk            BigInt    @id @default(autoincrement())
  trellisCaseNumber String    @db.VarChar(100)
  trellisUrl        String?   @db.Text
  trellisCaseId     String?   @db.Text
  courtId           BigInt?
  court             Court?    @relation(fields: [courtId], references: [courtId], onDelete: SetNull)
  caseCaption       String?   @db.Text
  practiceArea      String?   @db.Text
  caseCategory      String?   @db.Text
  caseType          String?   @db.Text
  matterType        String?   @db.Text
  filingDate        DateTime? @db.Date
  status            String?   @db.VarChar(100)
  isFederal         Boolean   @default(false)
  dispositionDate   DateTime? @db.Date
  dispositionType   String?   @db.Text
  verdictAmount     Decimal?  @db.Decimal(14, 2)
  sourceCaseJson    Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  docketEvents DocketEvent[]
  documents    Document[]
  complaintExtraction ComplaintExtraction?
  mlFeatureSnapshots MlFeatureSnapshot[]
  trialLabels  TrialLabels?

  @@unique([trellisCaseNumber, courtId])
  @@index([filingDate])
  @@index([status])
  @@map("cases")
}

model DocketEvent {
  docketEventId         BigInt   @id @default(autoincrement())
  casePk                BigInt
  caseRecord            CaseRecord @relation(fields: [casePk], references: [casePk], onDelete: Cascade)
  eventDate             DateTime @db.Date
  entryType             String?  @db.Text
  motionType            String?  @db.Text
  description           String   @db.Text
  fullDescription       String?  @db.Text
  filingPerson          String?  @db.Text
  judgeName             String?  @db.Text
  documentRequestToken  String?  @db.Text
  sourceEventJson       Json
  createdAt             DateTime @default(now())
  tags                  DocketEventTag[]
  documents             Document[]

  @@index([casePk, eventDate])
  @@map("docket_events")
}

model EventTypeMap {
  eventTypeCode String   @id @db.VarChar(100)
  description   String   @db.Text
  docketEventTags DocketEventTag[]

  @@map("event_type_map")
}

model DocketEventTag {
  docketEventTagId BigInt   @id @default(autoincrement())
  docketEventId   BigInt
  docketEvent     DocketEvent @relation(fields: [docketEventId], references: [docketEventId], onDelete: Cascade)
  eventTypeCode   String   @db.VarChar(100)
  eventTypeMap    EventTypeMap @relation(fields: [eventTypeCode], references: [eventTypeCode], onDelete: Restrict)
  confidence      Decimal  @default(1) @db.Decimal(4, 3)
  createdAt       DateTime @default(now())

  @@unique([docketEventId, eventTypeCode])
  @@index([docketEventId])
  @@index([eventTypeCode])
  @@map("docket_event_tags")
}

model Judge {
  judgeId          BigInt   @id @default(autoincrement())
  judgeName        String   @db.VarChar(500)
  courtId          BigInt?
  court            Court?   @relation(fields: [courtId], references: [courtId], onDelete: SetNull)
  appointedBy      String?  @db.Text
  barNumber        String?  @db.Text
  barAdmissionDate DateTime? @db.Date
  sourceJson       Json?

  @@unique([judgeName, courtId])
  @@map("judges")
}

model Document {
  documentId      BigInt   @id @default(autoincrement())
  casePk          BigInt
  caseRecord      CaseRecord @relation(fields: [casePk], references: [casePk], onDelete: Cascade)
  docketEventId   BigInt?
  docketEvent     DocketEvent? @relation(fields: [docketEventId], references: [docketEventId], onDelete: SetNull)
  documentTitle   String?  @db.Text
  documentType    String?  @db.Text
  filedDate       DateTime? @db.Date
  pageCount       Int?
  fileUrl         String?  @db.Text
  trellisToken    String?  @db.Text
  availability    String?  @db.Text
  textContent     String?  @db.Text
  textHash        String?  @db.Text
  sourceDocJson   Json?
  createdAt       DateTime @default(now())

  @@index([casePk])
  @@map("documents")
}

model ComplaintExtraction {
  casePk                  BigInt   @id
  caseRecord              CaseRecord @relation(fields: [casePk], references: [casePk], onDelete: Cascade)
  juryDemandFlag          Boolean?
  wrongfulDeathFlag       Boolean?
  survivalActionFlag      Boolean?
  medmalFlag              Boolean?
  grossNegligenceFlag     Boolean?
  injurySeverityLevel     Int?
  procedureComplexityLevel Int?
  allegationThemes        Json?    // e.g. ['anticoagulant', 'bleeding', 'failure_to_transfer']
  extractedPartiesCount    Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("complaint_extractions")
}

model MlFeatureSnapshot {
  snapshotId                    BigInt   @id @default(autoincrement())
  casePk                        BigInt
  caseRecord                    CaseRecord @relation(fields: [casePk], references: [casePk], onDelete: Cascade)
  cutoffType                    String   @db.VarChar(50)
  cutoffDate                    DateTime? @db.Date
  state                         String?  @db.Text
  county                        String?  @db.Text
  caseType                      String?  @db.Text
  matterType                    String?  @db.Text
  numDefendants                 Int?
  numPlaintiffs                 Int?
  corporateDefendantFlag        Boolean?
  medicalProfessionalDefendantFlag Boolean?
  juryDemandFlag                Boolean?
  wrongfulDeathFlag             Boolean?
  injurySeverityLevel           Int?
  procedureComplexityLevel      Int?
  motionCountTotal              Int?
  msjFiledFlag                  Boolean?
  juryFeesPostedFlag            Boolean?
  goodFaithSettlementFlag       Boolean?
  continuancesCount             Int?
  daysSinceFiling               Int?
  engineeredFeatures            Json?
  createdAt                     DateTime @default(now())

  @@unique([casePk, cutoffType])
  @@index([cutoffType])
  @@index([casePk])
  @@map("ml_feature_snapshots")
}

model TrialLabels {
  casePk           BigInt   @id
  caseRecord       CaseRecord @relation(fields: [casePk], references: [casePk], onDelete: Cascade)
  trialSetFlag     Boolean?
  reachedTrialFlag Boolean?

  @@map("trial_labels")
}

// Settlement Repository - benchmark data for case valuation
model SettlementRecord {
  id               String   @id @default(cuid())
  claimType        String   // auto, slip_and_fall, dog_bite, medmal, product, nursing_home_abuse, wrongful_death
  venueState       String
  venueCounty      String?
  injurySeverity   Int?     // 0-4 scale
  settlementAmount Float
  medCharges       Float?
  wageLoss         Float?
  treatmentMonths  Int?
  source           String?  // internal, public_record, anonymized
  createdAt        DateTime @default(now())

  @@index([claimType])
  @@index([venueState])
  @@index([injurySeverity])
  @@map("settlement_records")
}
