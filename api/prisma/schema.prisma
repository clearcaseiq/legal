generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  role          String    @default("client") // client, attorney, staff, admin
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // OAuth fields
  googleId String? @unique
  appleId  String? @unique
  avatar   String?
  provider String? // 'local', 'google', 'apple'

  // Consent tracking
  consents Consent[]

  assessments       Assessment[]
  favoriteAttorneys FavoriteAttorney[]
  notifications     Notification[]
  platformNotificationEvents PlatformNotificationEvent[]
  supportTickets    SupportTicket[]
  assignedTickets  SupportTicket[] @relation("AssignedTickets")
  appointments      Appointment[]
  reviews           AttorneyReview[]
  chatRooms         ChatRoom[]
  chatbotSessions   ChatBotSession[]
  evidenceFiles     EvidenceFile[]
  evidenceAnnotations EvidenceAnnotation[]
  auditLogs         AuditLog[]
  featureToggles    FeatureToggle[]
  attorneyPushDevices AttorneyPushDevice[]

  @@map("users")
}

model AttorneyPushDevice {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String   @unique @db.VarChar(512)
  platform      String? // ios, android
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("attorney_push_devices")
}

model Consent {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Consent type and version
  consentType String // 'hipaa', 'terms', 'privacy', 'marketing'
  version     String // Version of the consent document
  documentId  String // Reference to the consent document

  // Consent details
  granted   Boolean // Whether consent was granted
  grantedAt DateTime? // When consent was given
  revokedAt DateTime? // When consent was revoked
  expiresAt DateTime? // When consent expires (if applicable)

  // E-signature data
  signatureData   String? // Base64 encoded signature image
  signatureMethod String? // 'drawn', 'typed', 'clicked'
  ipAddress       String? // IP address when consent was given
  userAgent       String? // Browser user agent

  // Legal compliance
  consentText String @db.Text // The actual consent text that was shown
  consentHash String // Hash of the consent text for verification

  // Audit trail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("consents")
}

model Assessment {
  id          String  @id @default(cuid())
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimType   String
  venueState  String
  venueCounty String?
  status      String  @default("DRAFT")
  facts       String @db.Text

  // ChatGPT Analysis
  chatgptAnalysis     String? @db.Text // JSON string of ChatGPT analysis
  chatgptAnalysisDate DateTime?
  similarCases        String? // JSON string of similar case outcomes
  similarCasesUpdatedAt DateTime?

  // Case Tier Classification
  caseTierId  String?
  caseTier    CaseTier? @relation(fields: [caseTierId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  predictions   Prediction[]
  files         File[]
  introductions Introduction[]
  demandLetters DemandLetter[]
  appointments  Appointment[]
  chatRooms     ChatRoom[]
  evidenceFiles EvidenceFile[]
  ethicalWalls  EthicalWall[]

  // Lead Management
  leadSubmission LeadSubmission?

  // Routing lifecycle
  routingWaves RoutingWave[]

  // Attorney workflow
  insuranceDetails InsuranceDetail[]
  lienHolders      LienHolder[]
  caseTasks        CaseTask[]
  negotiationEvents NegotiationEvent[]
  decisionMemories  DecisionMemory[]
  negotiationInsight NegotiationInsight?
  caseNotes        CaseNote[]
  commentThreads   CaseCommentThread[]
  billingInvoices  BillingInvoice[]
  billingPayments  BillingPayment[]
  healthSnapshots  CaseHealthSnapshot[]
  caseReminders    CaseReminder[]
  recurringInvoices RecurringInvoice[]
  caseIntakeRequests CaseIntakeRequest[]
  caseShares       CaseShare[]
  referralAgreements ReferralAgreement[]
  coCounselWorkflows CoCounselWorkflow[]

  // Phase 2: Communications
  platformNotificationEvents PlatformNotificationEvent[]
  supportTickets    SupportTicket[]
  caseThreads       CaseThread[]

  // Manual review queue (held for low confidence, duplicate, near-SOL, etc.)
  manualReviewStatus  String?   // null | pending | released | rejected | request_info | compliance
  manualReviewReason  String?   // low_confidence | duplicate | conflicting_facts | suspicious_documents | near_sol | unsupported_jurisdiction | premium_case | ocr_failure
  manualReviewHeldAt  DateTime?
  manualReviewNote    String?   @db.Text

  @@map("assessments")
}

model InsuranceDetail {
  id            String     @id @default(cuid())
  assessmentId  String
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  carrierName   String
  policyNumber  String?
  policyLimit   Float?
  adjusterName  String?
  adjusterEmail String?
  adjusterPhone String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("insurance_details")
}

model LienHolder {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  name         String
  type         String?
  amount       Float?
  status       String     @default("open")
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("lien_holders")
}

model CaseTask {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  title        String
  taskType     String     @default("general") // statute, milestone, checkpoint, demand_deadline, negotiation_deadline, general
  milestoneType String?   // litigation_milestone
  checkpointType String?  // medical_checkpoint
  deadlineType  String?   // demand, negotiation, sol
  dueDate      DateTime?
  reminderAt   DateTime?
  escalationLevel String  @default("none") // none, warning, critical
  assignedRole   String?  // attorney, paralegal
  assignedTo     String?  // name or email
  status       String     @default("open") // open, done
  priority     String     @default("medium") // low, medium, high
  notes        String?
  sourceTemplateId String?
  sourceTemplateStepId String?
  completedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("case_tasks")
}

model CaseWorkflowTemplate {
  id         String   @id @default(cuid())
  attorneyId String
  attorney   Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  name       String
  caseType   String   // PI, MVA, Premises, MedMal, etc.
  description String?
  isActive   Boolean  @default(true)
  steps      CaseWorkflowStep[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("case_workflow_templates")
}

model CaseWorkflowStep {
  id          String              @id @default(cuid())
  templateId  String
  template    CaseWorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  offsetDays  Int
  priority    String   @default("medium")
  taskType    String   @default("general")
  milestoneType String?
  checkpointType String?
  deadlineType  String?
  assignedRole  String?
  reminderOffsetDays Int @default(1)
  escalationLevel String @default("none")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("case_workflow_steps")
}

model NegotiationEvent {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  eventType    String     // demand, offer, counter, call, note
  amount       Float?
  eventDate    DateTime   @default(now())
  status       String     @default("open") // open, pending, accepted, rejected
  notes        String?
  counterpartyType String? // insurer, claimant
  insurerName     String?
  adjusterName    String?
  adjusterEmail   String?
  adjusterPhone   String?
  concessionValue Float?
  concessionNotes String?
  acceptanceRationale String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("negotiation_events")
}

model NegotiationInsight {
  id           String     @id @default(cuid())
  assessmentId String     @unique
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  data         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("negotiation_insights")
}

model CaseNote {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  authorId     String?
  authorName   String?
  authorEmail  String?
  noteType     String     @default("general") // general, strategy, evidence, update
  message      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("case_notes")
}

model CaseCommentThread {
  id            String     @id @default(cuid())
  assessmentId  String
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  title         String
  threadType    String     @default("general") // general, decision
  allowedRoles  String?    // JSON array of roles allowed
  summary       String?
  createdById   String?
  createdByName String?
  createdByEmail String?
  lastCommentAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  comments CaseComment[]

  @@index([assessmentId])
  @@map("case_comment_threads")
}

model CaseComment {
  id           String            @id @default(cuid())
  threadId     String
  thread       CaseCommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId     String?
  authorName   String?
  authorEmail  String?
  message      String
  mentions     String? // JSON array of mention tokens/emails
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([threadId])
  @@map("case_comments")
}

model BillingInvoice {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  invoiceNumber String?
  amount       Float
  status       String     @default("open") // open, paid, overdue
  dueDate      DateTime?
  paidAt       DateTime?
  notes        String?
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  stripeCustomerId        String?
  stripePaymentStatus     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("billing_invoices")
}

model BillingPayment {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  amount       Float
  method       String?    // check, ach, card, cash
  receivedAt   DateTime   @default(now())
  reference    String?
  notes        String?
  processor    String?
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  stripeChargeId          String? @unique
  stripeCustomerId        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("billing_payments")
}

model PlatformPayment {
  id           String    @id @default(cuid())
  attorneyId   String
  attorney     Attorney  @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  type         String    // subscription, lead_credit, platform_fee
  amount       Float?
  currency     String    @default("usd")
  status       String
  stripeCustomerId        String?
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  stripeSubscriptionId    String?
  stripePriceId           String?
  metadata     String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([attorneyId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("platform_payments")
}

model CaseHealthSnapshot {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  score        Float
  level        String     // green, yellow, red
  factors      String?    // JSON
  createdAt    DateTime   @default(now())

  @@map("case_health_snapshots")
}

model ReminderTemplate {
  id         String   @id @default(cuid())
  attorneyId String
  attorney   Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  name       String
  channel    String   @default("email") // email, sms, call
  offsetDays Int      @default(3) // days after creation
  message    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  caseReminders CaseReminder[]

  @@map("reminder_templates")
}

model CaseReminder {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  templateId   String?
  template     ReminderTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel      String
  message      String
  dueAt        DateTime
  status       String     @default("scheduled") // scheduled, sent, dismissed, failed
  deliveryStatus String   @default("pending") // pending, delivered, failed
  attempts     Int        @default(0)
  sentAt       DateTime?
  lastAttemptAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("case_reminders")
}

model HealthEscalationRule {
  id         String   @id @default(cuid())
  attorneyId String
  attorney   Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  threshold  Float    // score <= threshold
  action     String   // recommended escalation action
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("health_escalation_rules")
}

model NegotiationCadenceTemplate {
  id              String   @id @default(cuid())
  attorneyId      String
  attorney        Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  name            String
  triggerEventType String  // offer, counter, demand
  isActive        Boolean  @default(true)
  steps           NegotiationCadenceStep[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("negotiation_cadence_templates")
}

model NegotiationCadenceStep {
  id          String                     @id @default(cuid())
  templateId  String
  template    NegotiationCadenceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  offsetDays  Int
  channel     String    // email, sms, call
  message     String
  sortOrder   Int       @default(0)

  @@map("negotiation_cadence_steps")
}

model TaskSlaTemplate {
  id            String   @id @default(cuid())
  attorneyId    String
  attorney      Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  name          String
  triggerStatus String   // contacted, consulted, retained
  isActive      Boolean  @default(true)
  steps         TaskSlaStep[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("task_sla_templates")
}

model TaskSlaStep {
  id          String        @id @default(cuid())
  templateId  String
  template    TaskSlaTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  offsetDays  Int
  priority    String @default("medium")

  @@map("task_sla_steps")
}

model RecurringInvoice {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  amount       Float
  intervalDays Int        @default(30)
  nextRunAt    DateTime
  lastRunAt    DateTime?
  status       String     @default("active") // active, paused
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("recurring_invoices")
}

model Prediction {
  id           String     @id @default(cuid())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String
  modelVersion String
  viability    String
  bands        String
  explain      String
  createdAt    DateTime   @default(now())

  @@map("predictions")
}

model Attorney {
  id                String   @id @default(cuid())
  name              String
  email             String?  @unique
  phone             String?
  specialties       String
  venues            String
  meta              String? @db.Text
  profile           String? @db.Text // Enhanced profile data (JSON)
  isActive          Boolean  @default(true)
  isVerified        Boolean  @default(false)
  responseTimeHours Int      @default(24)
  averageRating     Float    @default(0.0)
  totalReviews      Int      @default(0)
  lawFirmId         String?
  lawFirm           LawFirm? @relation(fields: [lawFirmId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  introductions     Introduction[]
  favoriteAttorneys FavoriteAttorney[]
  appointments      Appointment[]
  reviews           AttorneyReview[]
  availability      AttorneyAvailability[]
  chatRooms         ChatRoom[]
  ethicalWalls      EthicalWall[]
  caseSharesBy      CaseShare[]         @relation("CaseShareSharedByAttorney")
  caseSharesWith    CaseShare[]         @relation("CaseShareSharedWithAttorney")
  referralAgreementsReferring ReferralAgreement[] @relation("ReferralAgreementReferringAttorney")
  referralAgreementsReceiving ReferralAgreement[] @relation("ReferralAgreementReceivingAttorney")
  coCounselWorkflowsLead CoCounselWorkflow[] @relation("CoCounselWorkflowLeadAttorney")
  coCounselWorkflowsCoCounsel CoCounselWorkflow[] @relation("CoCounselWorkflowCoCounselAttorney")

  // Attorney Dashboard Relations
  dashboard         AttorneyDashboard?
  attorneyProfile   AttorneyProfile?   @relation("AttorneyProfile")
  leadSubmissions   LeadSubmission[]
  leadContacts      LeadContact[]
  caseContacts      CaseContact[]
  documentRequests  DocumentRequest[]
  leadAnalytics     LeadAnalytics[]
  conflictChecks    ConflictCheck[]
  providerReferrals ProviderReferral[]
  reminderTemplates ReminderTemplate[]
  healthRules       HealthEscalationRule[]
  negotiationCadenceTemplates NegotiationCadenceTemplate[]
  taskSlaTemplates           TaskSlaTemplate[]
  caseIntakeRequests         CaseIntakeRequest[]
  intakeConfig               AttorneyIntakeConfig?
  workflowTemplates          CaseWorkflowTemplate[]
  decisionMemories           DecisionMemory[]
  decisionProfile            AttorneyDecisionProfile?
  auditLogs                  AuditLog[]
  smsWebhookReceipts         SmsWebhookReceipt[]
  reputationScore            AttorneyReputationScore?
  importSources              AttorneyImportSource[]
  calendarConnections        AttorneyCalendarConnection[]
  calendarBusyBlocks         AttorneyCalendarBusyBlock[]
  platformPayments           PlatformPayment[]

  // Phase 2: Communications
  platformNotificationEvents PlatformNotificationEvent[]
  supportTickets             SupportTicket[]

  @@index([phone])
  @@map("attorneys")
}

model LawFirm {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  primaryEmail String?
  phone        String?
  website      String?
  address      String?
  city         String?
  state        String?
  zip          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decisionMemories DecisionMemory[]
  decisionProfiles AttorneyDecisionProfile[]

  // Relations
  attorneys Attorney[]
  settings  FirmSetting[]
  featureToggles FeatureToggle[]

  @@map("law_firms")
}

model FirmSetting {
  id        String   @id @default(cuid())
  lawFirmId String
  lawFirm   LawFirm  @relation(fields: [lawFirmId], references: [id], onDelete: Cascade)
  key       String
  value     String   // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lawFirmId, key])
  @@index([lawFirmId])
  @@map("firm_settings")
}

model FeatureToggle {
  id          String   @id @default(cuid())
  key         String
  description String?
  enabled     Boolean  @default(false)
  scope       String   @default("global") // global, firm, user
  lawFirmId   String?
  lawFirm     LawFirm? @relation(fields: [lawFirmId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, scope, lawFirmId, userId])
  @@index([key])
  @@index([lawFirmId])
  @@index([userId])
  @@map("feature_toggles")
}

model AttorneyDecisionProfile {
  id              String   @id @default(cuid())
  attorneyId      String   @unique
  attorney        Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  lawFirmId       String?
  lawFirm         LawFirm? @relation(fields: [lawFirmId], references: [id], onDelete: SetNull)
  negotiationStyle String?
  riskTolerance    String?
  preferences      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([lawFirmId])
  @@map("attorney_decision_profiles")
}

model File {
  id            String      @id @default(cuid())
  assessment    Assessment? @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String?
  originalName  String
  filename      String
  mimetype      String
  size          Int
  path          String
  status        String      @default("UPLOADED")
  extractedText String?
  summary       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("files")
}

model Introduction {
  id           String     @id @default(cuid())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String
  attorney     Attorney   @relation(fields: [attorneyId], references: [id])
  attorneyId   String
  status       String     @default("PENDING") // PENDING, ACCEPTED, DECLINED, REQUESTED_INFO
  message      String     @default("")
  requestedAt  DateTime   @default(now())
  respondedAt  DateTime?
  declineReason String?   // Reason when status=DECLINED
  requestedInfoNotes String? @db.Text // Notes when status=REQUESTED_INFO
  waveNumber   Int       @default(1) // Which routing wave this was part of
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([attorneyId, status, requestedAt])
  @@index([assessmentId])
  @@map("introductions")
}

model SmsWebhookReceipt {
  id               String    @id @default(cuid())
  provider         String    @default("twilio")
  messageSid       String?   @unique
  requestId        String?
  fromPhone        String?
  normalizedFrom   String?
  messageBody      String?   @db.Text
  decision         String?
  attorneyId       String?
  responseCode     Int?
  responseMessage  String?   @db.Text
  processingStatus String    @default("received") // received, processed, ignored, duplicate, failed
  introductionId   String?
  leadSubmissionId String?
  errorMessage     String?   @db.Text
  processedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  attorney Attorney? @relation(fields: [attorneyId], references: [id], onDelete: SetNull)

  @@index([attorneyId])
  @@index([processingStatus, createdAt])
  @@index([introductionId])
  @@index([leadSubmissionId])
  @@map("sms_webhook_receipts")
}

model RoutingWave {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  waveNumber   Int        // 1, 2, 3
  attorneyIds  String     // JSON array of attorney IDs in this wave
  sentAt       DateTime   @default(now())
  nextEscalationAt DateTime? // When to run wave N+1 if no response
  escalatedAt  DateTime?  // When wave 2/3 was actually sent
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([assessmentId, waveNumber])
  @@index([assessmentId])
  @@index([nextEscalationAt])
  @@map("routing_waves")
}

model RoutingAnalytics {
  id           String     @id @default(cuid())
  assessmentId String
  introductionId String?
  attorneyId   String?
  eventType    String     // routed, viewed, accepted, declined, requested_info, escalated
  eventData    String?    @db.Text // JSON: declineReason, responseTimeMs, etc.
  createdAt    DateTime   @default(now())

  @@index([assessmentId])
  @@index([attorneyId])
  @@index([eventType])
  @@map("routing_analytics")
}

model AttorneyReputationScore {
  id           String     @id @default(cuid())
  attorneyId   String     @unique
  attorney     Attorney   @relation(fields: [attorneyId], references: [id], onDelete: Cascade)
  responseSpeedScore Float @default(0)   // 0-1
  acceptanceRate     Float @default(0)   // 0-1
  plaintiffSatisfaction Float @default(0) // 0-1
  caseFollowThrough  Float @default(0)   // 0-1
  evidenceRequestQuality Float @default(0) // 0-1
