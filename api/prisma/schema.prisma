model AttorneyProfile {
  id         String   @id @default(cuid())
  attorneyId String   @unique
  attorney   Attorney @relation("AttorneyProfile", fields: [attorneyId], references: [id], onDelete: Cascade)

  // Profile Details
  bio         String?
  photoUrl    String?
  specialties String? // JSON array of specialties
  languages   String? // JSON array of languages

  // Success Stats
  yearsExperience   Int   @default(0)
  totalCases        Int   @default(0)
  totalSettlements  Float @default(0)
  averageSettlement Float @default(0)
  successRate       Float @default(0)

  // Verified Verdicts
  verifiedVerdicts String? @db.Text // JSON array of verified case outcomes

  // Featured Placement
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?
  boostLevel    Int       @default(0) // 0-5 boost level

  // Reviews & Ratings
  totalReviews  Int   @default(0)
  averageRating Float @default(0)

  // ===== FIRM INFORMATION =====
  firmName      String? // Firm name
  firmWebsite   String? // Firm website URL
  firmLocations String? // JSON array of locations {address, city, state, zip, phone}

  // ===== JURISDICTIONS =====
  jurisdictions String? // JSON array of {state, counties: [], cities: []} - counties/cities covered
  secondaryCaseTypes String? // JSON array of secondary case types

  // ===== CASE PREFERENCES =====
  minInjurySeverity Int? // Minimum injury severity level (0-4) they accept
  excludedCaseTypes String? // JSON array of case types to exclude
  minDamagesRange   Float? // Minimum damages range they accept
  maxDamagesRange   Float? // Maximum damages range they accept (null = no max)
  insuranceRequired Boolean? // Require insurance on cases
  mustHaveMedicalTreatment Boolean? // Require medical treatment
  requirePoliceReport Boolean? // Require police report
  requireMedicalRecords Boolean? // Require medical records

  // ===== CAPACITY SIGNALS =====
  maxCasesPerWeek  Int? // Maximum new cases per week
  maxCasesPerMonth Int? // Maximum new cases per month
  intakeHours      String? // JSON array of {dayOfWeek, startTime, endTime} or "24/7"

  // ===== BUYING PREFERENCES =====
  pricingModel     String? // 'fixed_price', 'auction', 'both'
  paymentModel     String? // 'subscription', 'pay_per_case', 'both'
  subscriptionTier String? // 'basic', 'premium', 'enterprise' (if subscription)
  
  // ===== SUBSCRIPTION & ACCOUNT TRACKING =====
  subscriptionActive      Boolean  @default(false) // Whether subscription is currently active
  subscriptionRemainingCases Int?  // Remaining cases in current subscription period
  accountBalance           Float   @default(0) // Account balance for pay-per-case
  tier1Enabled             Boolean @default(false) // Enable Tier 1 routing
  tier2Enabled             Boolean @default(false) // Enable Tier 2 routing
  stripeCustomerId         String? @unique
  stripeSubscriptionId     String? @unique
  stripeSubscriptionStatus String?
  stripeSubscriptionPriceId String?
  stripeCurrentPeriodEnd   DateTime?
  stripeConnectAccountId   String? @unique
  stripeConnectChargesEnabled Boolean @default(false)
  stripeConnectPayoutsEnabled Boolean @default(false)
  
  // ===== ROUTING METRICS (calculated/aggregated) =====
  historicalAcceptanceRate Float? // Historical acceptance rate (0-1)
  responseSpeedScore       Float? // Response speed score (0-1)
  recentConversionScore    Float? // Recent conversion score (0-1)
  recentTier1ConversionRate Float? // Tier 1 specific conversion rate (0-1)
  recentTier2ConversionRate Float? // Tier 2 specific conversion rate (0-1)
  accountBalanceWeight     Float? // Account balance weight for ranking (0-1)

  // ===== ATTORNEY LICENSE =====
  licenseNumber    String? // State bar license number
  licenseState     String? // State where licensed (2-letter code)
  licenseFileUrl   String? // URL/path to uploaded license file
  licenseFileName  String? // Original filename of license document
  licenseVerified  Boolean @default(false) // Whether license has been verified
  licenseVerifiedAt DateTime? // When license was verified
  licenseVerificationMethod String? // 'state_bar_lookup', 'manual_upload', 'admin_review'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attorney_profiles")
}

