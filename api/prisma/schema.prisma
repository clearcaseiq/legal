  // Lawyer Profile
  lawyerProfile String // "High-volume PI shops", etc.

  // Goal
  goal String // "Liquidity, scale, predictable flow", etc.

  // Case Types (JSON array)
  caseTypes String // JSON array of case types

  // Characteristics (JSON array)
  characteristics String // JSON array of characteristics

  // Promotion Rules (JSON) - Conditions that can promote cases to higher tiers
  promotionRules String? // JSON object with promotion conditions

  // Metadata
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assessments Assessment[]

  @@map("case_tiers")
}

