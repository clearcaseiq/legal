# Injury Intelligence API base URL (no trailing slash).
#
# Physical phone: MUST be your PC's LAN IP, not localhost (localhost = the phone itself).
#   Example: http://192.168.1.212:4000
#   Find IP: Windows `ipconfig` → IPv4 under your active Wi‑Fi adapter.
# iOS Simulator / same machine: http://localhost:4000 is OK.
# Android emulator (AVD): use http://10.0.2.2:4000 to reach the host PC.
#
# After changing this file, stop Expo (Ctrl+C) and run `pnpm start` again.
EXPO_PUBLIC_API_URL=http://localhost:4000
