# Copy to .env.prod on the EC2 host and fill real values.
# Never commit .env.prod.

# PostgreSQL container credentials (used only when DATABASE_URL is unset)
POSTGRES_USER=clearcaseiq
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=clearcaseiq

# Production database — set to Supabase (recommended) or leave unset to use the EC2 db container.
# Supabase: Project Settings → Database → URI (Direct, port 5432). Add sslmode=require for EC2.
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.ejytyijftscatknlsngq.supabase.co:5432/postgres?sslmode=require

# API required secrets
JWT_SECRET=replace-with-long-random-secret
SESSION_SECRET=replace-with-long-random-session-secret

# Public production URLs
API_URL=https://api.clearcaseiq.com
WEB_URL=https://www.clearcaseiq.com
FRONTEND_URL=https://www.clearcaseiq.com
CORS_ORIGINS=https://www.clearcaseiq.com,https://clearcaseiq.com
TRUST_PROXY=1

# AWS document storage / OCR
AWS_REGION=us-east-1
FILE_BUCKET=s3
S3_BUCKET=replace-with-s3-bucket-name
OCR_PROVIDER=aws_textract
ENABLE_OCR=true
PDF_TEXTRACT_FALLBACK=true

# AI / ML
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
ML_PREDICTION_MODE=fallback
ML_SERVICE_URL=
ML_RETRIEVAL_ENABLED=false
ML_RETRIEVAL_TOP_K=4
ML_REQUEST_TIMEOUT_MS=5000

# Auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.clearcaseiq.com/v1/auth/google/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=https://api.clearcaseiq.com/v1/auth/apple/callback
# Microsoft Entra ID LOGIN (attorney sign-in) — separate from MICROSOFT_CALENDAR_* below.
# Azure Portal → App registrations → Redirect URI (Web):
#   https://api.clearcaseiq.com/v1/auth/microsoft/callback
# tenant: "common" (work + personal), "organizations", or your tenant GUID.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=https://api.clearcaseiq.com/v1/auth/microsoft/callback

# Payments / communications
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_SUBSCRIPTION_PRICE_ID=
STRIPE_LEAD_CREDIT_PRICE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMS provider: "sns" (Amazon SNS) or "twilio". If unset, auto-detects Twilio when
# its three vars above are set; SNS must be selected explicitly.
SMS_PROVIDER=sns
# Amazon SNS SMS uses the EC2 instance IAM role for auth (no keys needed); it needs
# the sns:Publish permission. AWS_REGION is already set above (SNS_REGION overrides it).
# SNS_REGION=us-east-1
# Your provisioned origination number in E.164 (10DLC or toll-free), required for US A2P.
SNS_ORIGINATION_NUMBER=
# Transactional (higher delivery priority) or Promotional.
SNS_SMS_TYPE=Transactional
# Alphabetic sender ID — only supported in some countries, NOT US/Canada. Leave blank for US.
SNS_SENDER_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Email provider selection: "ses" (Amazon SES) or "resend".
# If unset, auto-detects: SES when SES_FROM_EMAIL is set, otherwise Resend.
EMAIL_PROVIDER=ses
# Amazon SES (uses the EC2 instance IAM role for auth — no keys needed).
# Must be a verified SES identity/domain; AWS_REGION is already set above.
SES_FROM_EMAIL=ClearCaseIQ <noreply@clearcaseiq.com>
# Optional: SES configuration set for open/click/bounce tracking.
SES_CONFIGURATION_SET=

# Production behavior
REQUIRE_EMAIL_VERIFICATION=false
ADMIN_EMAILS=admin@clearcaseiq.com

# Attorney calendar sync
# Google Cloud OAuth redirect URI:
# https://api.clearcaseiq.com/v1/attorney-calendar/callback/google
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://api.clearcaseiq.com/v1/attorney-calendar/callback/google
GOOGLE_CALENDAR_WEBHOOK_URI=https://api.clearcaseiq.com/v1/attorney-calendar/webhooks/google

# Microsoft Entra ID OAuth redirect URI:
# https://api.clearcaseiq.com/v1/attorney-calendar/callback/microsoft
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_REDIRECT_URI=https://api.clearcaseiq.com/v1/attorney-calendar/callback/microsoft
MICROSOFT_CALENDAR_WEBHOOK_URI=https://api.clearcaseiq.com/v1/attorney-calendar/webhooks/microsoft
CALENDAR_WEBHOOK_RENEWAL_ENABLED=true
CALENDAR_WEBHOOK_RENEWAL_INTERVAL_MS=900000
